generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DENTIST
  RECEP
  FINANCE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id           String   @id @default(uuid())
  enterpriseId String   @map("enterprise_id")
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(RECEP)
  phone        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enterprise   Enterprise   @relation(fields: [enterpriseId], references: [id])
  appointments Appointment[]
  userPermissions UserPermission[]

  @@map("users")
}

model Patient {
  id              String    @id @default(uuid())
  enterpriseId    String    @map("enterprise_id")
  name            String
  gender          String?
  document        String?   @unique @map("document")
  nationality     String?
  email           String?   @unique
  phone           String
  recordNumber    String?   @map("record_number")
  occupation      String?
  birthDate       DateTime? @map("birth_date")
  address         String?
  tags            Json?
  guardianName        String?   @map("guardian_name")
  guardianBirthDate   DateTime? @map("guardian_birth_date")
  guardianDocument    String?   @map("guardian_document")
  guardianPhone       String?   @map("guardian_phone")
  healthPlanId    String?   @map("health_plan_id")
  notes           String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  enterprise   Enterprise   @relation(fields: [enterpriseId], references: [id])
  appointments Appointment[]
  healthPlan   HealthPlan?  @relation(fields: [healthPlanId], references: [id])

  @@map("patients")
}

model HealthPlan {
  id           String   @id @default(uuid())
  enterpriseId String   @map("enterprise_id")
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  patients   Patient[]

  @@map("health_plans")
}

model Appointment {
  id           String            @id @default(uuid())
  enterpriseId String            @map("enterprise_id")
  date         DateTime
  endTime      DateTime?         @map("end_time")
  status       AppointmentStatus @default(SCHEDULED)
  notes        String?
  tag          String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  patientId String @map("patient_id")
  dentistId String @map("dentist_id")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  patient   Patient    @relation(fields: [patientId], references: [id])
  dentist   User       @relation(fields: [dentistId], references: [id])

  @@map("appointments")
}

model Treatment {
  id           String   @id @default(uuid())
  enterpriseId String   @map("enterprise_id")
  description  String
  value        Decimal
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])

  @@map("treatments")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  module      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  role         String
  permissionId String
  createdAt    DateTime @default(now()) @map("created_at")

  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model Question {
  id            String   @id @default(uuid())
  enterpriseId  String   @map("enterprise_id")
  pergunta      String
  tipo          Int      @default(1)
  alerta        Int      @default(1)
  labelPergunta String?  @map("label_pergunta")
  labelAlerta   String?  @map("label_alerta")
  opcoes        Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  enterprise Enterprise         @relation(fields: [enterpriseId], references: [id])
  anamneses  AnamnesisQuestion[]

  @@map("questions")
}

model Anamnesis {
  id           String   @id @default(uuid())
  enterpriseId String   @map("enterprise_id")
  nome         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enterprise Enterprise         @relation(fields: [enterpriseId], references: [id])
  questions  AnamnesisQuestion[]

  @@map("anamneses")
}

model AnamnesisQuestion {
  id           String    @id @default(uuid())
  anamnesisId  String    @map("anamnesis_id")
  questionId   String    @map("question_id")
  ordem        Int       @default(0)
  obrigatorio  Boolean   @default(false)

  anamnesis Anamnesis @relation(fields: [anamnesisId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id])

  @@unique([anamnesisId, questionId])
  @@map("anamnesis_questions")
}

model Enterprise {
  id      String  @id @default(uuid())
  cnpj    String?
  nome    String?
  phone   String?
  email        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  logo         String?
  active  Boolean @default(true)

  users        User[]
  patients     Patient[]
  appointments Appointment[]
  treatments   Treatment[]
  healthPlans  HealthPlan[]
  questions    Question[]
  anamneses    Anamnesis[]

  @@map("enterprises")
}